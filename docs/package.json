{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tinacms build && next build",
    "build:local": "tinacms build --local --skip-cloud-checks -c \"next build\"",
    "dev": "tinacms dev -c \"next dev\"",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@fumadocs/mdx-remote": "^1.4.10",
    "@mdx-js/mdx": "^3.1.1",
    "@tinacms/bridge": "^0.3.0",
    "@tinacms/mdx": "^2.1.7",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-ui": "16.10.7",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tinacms": "^3.9.3",
    "tinacms-fumadocs-pkg": "github:0xharkirat/tinacms-fumadocs-pkg"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tinacms/cli": "^2.5.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
